POSTGRES_DB=originpulse
POSTGRES_USER=originpulse
POSTGRES_PASSWORD=originpulse_dev_password
POSTGRES_PORT=55432
ORIGINPULSE_PORT=8080

# Required for log collection inside Docker.
PANTHEON_SSH_KEY_FILE=C:/Users/example/.ssh/id_rsa

# Optional Pantheon/API and notification settings.
PANTHEON_EMAIL=
PANTHEON_MACHINE_TOKEN=
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:12b
ORIGINPULSE_SMTP_USERNAME=
ORIGINPULSE_SMTP_PASSWORD=
ORIGINPULSE_PUSH_WEBHOOK_URLS=
ORIGINPULSE_VAPID_PUBLIC_KEY=
ORIGINPULSE_VAPID_PRIVATE_KEY=
ORIGINPULSE_VAPID_SUBJECT=mailto:originpulse@localhost
LOG_LEVEL=info
